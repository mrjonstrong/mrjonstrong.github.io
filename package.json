{
	"name": "astro-cactus",
	"type": "module",
	"packageManager": "pnpm@10.29.3",
	"version": "6.11.0",
	"private": false,
	"scripts": {
		"postinstall": "pnpm rebuild sharp",
		"dev": "astro dev",
		"start": "astro dev",
		"build": "astro build",
		"postbuild": "sh -c 'pagefind --site dist; pagefind_status=$?; node scripts/verify-csp-hashes.mjs; csp_status=$?; if [ $pagefind_status -ne 0 ] || [ $csp_status -ne 0 ]; then exit 1; fi'",
		"preview": "astro preview",
		"check": "astro check && biome check",
		"lint": "biome check --write",
		"format": "prettier -w . --cache"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"dependencies": {
		"@astrojs/markdown-remark": "^7.1.1",
		"@astrojs/mdx": "5.0.4",
		"@astrojs/rss": "4.0.18",
		"@astrojs/sitemap": "3.7.2",
		"@tailwindcss/vite": "4.3.0",
		"astro": "6.3.1",
		"astro-expressive-code": "^0.42.0",
		"astro-icon": "^1.1.5",
		"astro-robots-txt": "^1.0.0",
		"astro-webmanifest": "^1.0.0",
		"cssnano": "^7.1.7",
		"hastscript": "^9.0.1",
		"mdast-util-directive": "^3.1.0",
		"mdast-util-to-markdown": "^2.1.2",
		"mdast-util-to-string": "^4.0.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-external-links": "^3.0.0",
		"rehype-unwrap-images": "^1.0.0",
		"remark-directive": "^4.0.0",
		"satori": "0.26.0",
		"satori-html": "^0.3.2",
		"sharp": "^0.34.5",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.1.0"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@biomejs/biome": "^2.4.15",
		"@iconify-json/mdi": "^1.2.3",
		"@pagefind/default-ui": "^1.5.2",
		"@resvg/resvg-js": "^2.6.2",
		"@tailwindcss/typography": "^0.5.19",
		"@types/hast": "^3.0.4",
		"@types/mdast": "^4.0.4",
		"autoprefixer": "^10.5.0",
		"lighthouse": "^13.3.0",
		"node-html-parser": "^7.1.0",
		"pagefind": "^1.5.2",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "0.14.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"reading-time": "^1.5.0",
		"tailwindcss": "4.3.0",
		"typescript": "^5.9.3"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["@biomejs/biome", "@tailwindcss/oxide", "esbuild", "sharp"],
		"overrides": {
			"sharp": "^0.34.5",
			"lodash": ">=4.17.23",
			"@ungap/structured-clone": ">=1.3.1"
		}
	},
	"overrides": {
		"sharp": "^0.34.5"
	}
}
